logs/
*.log

# Secrets — NEVER commit these
.env
*.env
kaggle.json

# Experiment outputs — regenerate with evaluate.py
experiments/figures/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS files
.DS_Store
Thumbs.db

# Keep empty folders
!**/.gitkeep
