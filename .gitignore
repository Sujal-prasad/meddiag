# Virtual environment
.venv/
venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Model weights — too large for GitHub (use HuggingFace Hub instead)
models/
*.safetensors
*.bin
*.pt
*.pth
*.ckpt

